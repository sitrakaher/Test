generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Campaigns {
  id                String         @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  advertiser        String
  startDate         DateTime
  endDate           DateTime
  budget            Float
  impressionsServed Int            @default(0)
  targetCountries   String[]
  status            CampaignStatus
}

enum CampaignStatus {
  active
  paused
  ended
}
